{
    "name": "waaseyaa/routing",
    "description": "HTTP routing and controller resolution for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../access"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../i18n"}
    ],
    "require": {
        "php": ">=8.3",
        "waaseyaa/entity": "@dev",
        "waaseyaa/access": "@dev",
        "waaseyaa/i18n": "@dev",
        "symfony/routing": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Routing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Routing\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
