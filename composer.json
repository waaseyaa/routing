{
    "name": "aurora/routing",
    "description": "HTTP routing and controller resolution for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "aurora/entity": "^0.1",
        "aurora/access": "^0.1",
        "symfony/routing": "^7.3",
        "symfony/http-kernel": "^7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Routing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Routing\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
